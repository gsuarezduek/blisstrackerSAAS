generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model UserRole {
  id        Int      @id @default(autoincrement())
  name      String   @unique   // identificador interno, ej: "DESIGNER"
  label     String             // nombre para mostrar, ej: "Diseñador"
  createdAt DateTime @default(now())
}

enum TaskStatus {
  PENDING
  IN_PROGRESS
  PAUSED
  BLOCKED
  COMPLETED
}

model User {
  id        Int      @id @default(autoincrement())
  name      String
  email     String   @unique
  password  String
  role      String
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Datos personales (opcionales)
  phone            String?
  birthday         DateTime?
  address          String?
  dni              String?
  cuit             String?
  alias            String?
  maritalStatus    String?
  children         Int?
  educationLevel   String?
  educationTitle   String?
  bloodType        String?
  medicalConditions String?
  healthInsurance  String?
  emergencyContact String?
  avatar              String   @default("bee.png")
  weeklyEmailEnabled  Boolean  @default(true)
  dailyInsightEnabled Boolean  @default(true)

  workDays      WorkDay[]
  tasks         Task[]
  tasksCreated  Task[]         @relation("TaskCreatedBy")
  feedbacks     Feedback[]
  projects      ProjectMember[]
  notifications         Notification[] @relation("NotificationRecipient")
  notificationsAsActor  Notification[] @relation("NotificationActor")
  passwordResetTokens   PasswordResetToken[]
}

model PasswordResetToken {
  id        Int      @id @default(autoincrement())
  token     String   @unique
  userId    Int
  user      User     @relation(fields: [userId], references: [id])
  expiresAt DateTime
  used      Boolean  @default(false)
  createdAt DateTime @default(now())
}

model Feedback {
  id        Int          @id @default(autoincrement())
  userId    Int
  user      User         @relation(fields: [userId], references: [id])
  type      FeedbackType
  message   String
  read      Boolean      @default(false)
  createdAt DateTime     @default(now())
}

enum FeedbackType {
  SUGGESTION
  BUG
}

enum NotificationType {
  COMPLETED
  BLOCKED
}

model Project {
  id        Int      @id @default(autoincrement())
  name      String   @unique
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tasks         Task[]
  services      ProjectService[]
  members       ProjectMember[]
  notifications Notification[]
  links         ProjectLink[]
}

model Service {
  id        Int      @id @default(autoincrement())
  name      String   @unique
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  projects ProjectService[]
}

model ProjectService {
  projectId Int
  serviceId Int
  project   Project @relation(fields: [projectId], references: [id])
  service   Service @relation(fields: [serviceId], references: [id])

  @@id([projectId, serviceId])
}

model ProjectMember {
  projectId Int
  userId    Int
  project   Project @relation(fields: [projectId], references: [id])
  user      User    @relation(fields: [userId], references: [id])

  @@id([projectId, userId])
}

model ProjectLink {
  id        Int      @id @default(autoincrement())
  projectId Int
  project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  label     String
  url       String
  createdAt DateTime @default(now())

  @@index([projectId])
}

model WorkDay {
  id        Int       @id @default(autoincrement())
  userId    Int
  user      User      @relation(fields: [userId], references: [id])
  date      String    // "YYYY-MM-DD"
  startedAt DateTime  @default(now())
  endedAt   DateTime?
  createdAt DateTime  @default(now())

  tasks Task[]

  @@unique([userId, date])
  @@index([date])
}

model Notification {
  id        Int              @id @default(autoincrement())
  userId    Int                                         // destinatario
  user      User             @relation("NotificationRecipient", fields: [userId], references: [id])
  actorId   Int                                         // quien realizó la acción
  actor     User             @relation("NotificationActor",    fields: [actorId], references: [id])
  taskId    Int
  task      Task             @relation(fields: [taskId], references: [id])
  projectId Int
  project   Project          @relation(fields: [projectId], references: [id])
  type      NotificationType @default(COMPLETED)
  message   String
  read      Boolean          @default(false)
  createdAt DateTime         @default(now())

  @@index([userId])
}

model Task {
  id          Int        @id @default(autoincrement())
  workDayId   Int
  workDay     WorkDay    @relation(fields: [workDayId], references: [id])
  userId      Int
  user        User       @relation(fields: [userId], references: [id])
  createdById Int?
  createdBy   User?      @relation("TaskCreatedBy", fields: [createdById], references: [id])
  projectId   Int
  project     Project    @relation(fields: [projectId], references: [id])
  description   String
  status        TaskStatus @default(PENDING)
  blockedReason String?
  startedAt     DateTime?
  pausedAt      DateTime?
  pausedMinutes   Int        @default(0)
  completedAt     DateTime?
  minutesOverride Int?
  starred         Int        @default(0)  // 0=sin estrella 1=amarillo 2=naranja 3=rojo
  createdAt       DateTime   @default(now())
  updatedAt     DateTime   @updatedAt

  notifications Notification[]

  @@index([userId, status])
  @@index([projectId])
}
