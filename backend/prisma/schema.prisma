generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── WORKSPACE ───────────────────────────────────────────────────────────────

model Workspace {
  id               Int      @id @default(autoincrement())
  name             String
  slug             String   @unique   // subdominio, ej: "bliss"
  timezone         String   @default("America/Argentina/Buenos_Aires")
  status           String   @default("trialing") // trialing | active | past_due | suspended | cancelled
  trialEndsAt      DateTime?
  stripeCustomerId String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  members          WorkspaceMember[]
  projects         Project[]
  userRoles        UserRole[]
  services         Service[]
  roleExpectations RoleExpectation[]
  aiTokenLogs      AiTokenLog[]
  dailyInsights    DailyInsight[]
  insightMemories  UserInsightMemory[]
  notifications    Notification[]
  workDays         WorkDay[]
  subscription     Subscription?
  loginEvents      UserLogin[]
  feedbacks        Feedback[]
  invitations      WorkspaceInvitation[]
  deletionRequest  WorkspaceDeletionRequest?
  emailLogs            EmailLog[]
  vacationAdjustments  VacationAdjustment[]
  vacationRequests     VacationRequest[]
  geoAudits            GeoAudit[]
  integrations         ProjectIntegration[]
  analyticsSnapshots   AnalyticsSnapshot[]
  analyticsInsights    AnalyticsInsight[]
  pageSpeedResults     PageSpeedResult[]
  trackedKeywords      TrackedKeyword[]   @relation("WorkspaceTrackedKeywords")
  keywordRankings      KeywordRanking[]   @relation("WorkspaceKeywordRankings")
  instagramSnapshots        InstagramSnapshot[]
  instagramFollowerLogs     InstagramFollowerLog[]
  tiktokSnapshots           TikTokSnapshot[]
  tiktokFollowerLogs        TikTokFollowerLog[]
  monthlyReports            MonthlyReport[]
  searchConsoleSnapshots    SearchConsoleSnapshot[]
  seoAiInsights             SeoAiInsight[]
  cannibalReports           CannibalReport[]

  @@index([slug])
}

model WorkspaceMember {
  workspaceId Int
  userId      Int
  workspace   Workspace @relation(fields: [workspaceId], references: [id])
  user        User      @relation(fields: [userId], references: [id])

  role        String    @default("member")   // "owner" | "admin" | "member"
  teamRole    String    @default("")          // ej: "DESIGNER", "CM" (referencia a UserRole.name)
  active      Boolean   @default(true)
  vacationDays Int      @default(0)

  // Preferencias IA (por workspace)
  weeklyEmailEnabled    Boolean @default(true)
  dailyInsightEnabled   Boolean @default(true)
  insightMemoryEnabled  Boolean @default(true)
  taskQualityEnabled    Boolean @default(true)

  joinedAt    DateTime  @default(now())

  @@id([workspaceId, userId])
  @@index([workspaceId])
  @@index([userId])
}

model Subscription {
  id             Int      @id @default(autoincrement())
  workspaceId    Int      @unique
  workspace      Workspace @relation(fields: [workspaceId], references: [id])
  stripeSubId    String?  @unique
  planName       String   @default("pro")
  status         String   // active | past_due | cancelled | trialing
  seats          Int      @default(0)
  periodStart    DateTime?
  periodEnd      DateTime?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}

// ─── USER (global — datos personales, no workspace-specific) ─────────────────

model User {
  id        Int      @id @default(autoincrement())
  name      String
  email     String   @unique
  password  String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Super admin global (solo equipo Bliss)
  isSuperAdmin Boolean @default(false)

  // Datos personales (opcionales, globales al usuario)
  phone             String?
  birthday          DateTime?
  address           String?
  dni               String?
  cuit              String?
  alias             String?
  bankName          String?
  maritalStatus     String?
  children          Int?
  educationLevel    String?
  educationTitle    String?
  bloodType         String?
  medicalConditions String?
  healthInsurance   String?
  emergencyContact  String?
  avatar            String   @default("2bee.png")

  // Relaciones
  workspaceMembers      WorkspaceMember[]
  workDays              WorkDay[]
  tasks                 Task[]
  tasksCreated          Task[]         @relation("TaskCreatedBy")
  taskComments          TaskComment[]
  dailyInsights         DailyInsight[]
  insightMemories       UserInsightMemory[]
  feedbacks             Feedback[]
  projects              ProjectMember[]
  notifications         Notification[] @relation("NotificationRecipient")
  notificationsAsActor  Notification[] @relation("NotificationActor")
  passwordResetTokens   PasswordResetToken[]
  loginEvents           UserLogin[]
  sentInvitations           WorkspaceInvitation[]      @relation("InvitedByUser")
  deletionRequestsMade      WorkspaceDeletionRequest[] @relation("DeletionRequestedBy")
  deletionRequestsCancelled WorkspaceDeletionRequest[] @relation("DeletionCancelledBy")
  vacationAdjustments       VacationAdjustment[]       @relation("VacationAdjustmentUser")
  vacationAdjustmentsAdmin  VacationAdjustment[]       @relation("VacationAdjustmentAdmin")
  vacationRequests          VacationRequest[]          @relation("VacationRequestUser")
  vacationRequestsReviewed  VacationRequest[]          @relation("VacationRequestReviewer")
  announcements             Announcement[]             @relation("AnnouncementCreatedBy")
}

model UserLogin {
  id          Int       @id @default(autoincrement())
  userId      Int
  user        User      @relation(fields: [userId], references: [id])
  workspaceId Int?
  workspace   Workspace? @relation(fields: [workspaceId], references: [id])
  loginAt     DateTime  @default(now())
  method      String    // "email" | "google"

  @@index([userId])
  @@index([workspaceId])
  @@index([loginAt])
}

model PasswordResetToken {
  id        Int      @id @default(autoincrement())
  token     String   @unique
  userId    Int
  user      User     @relation(fields: [userId], references: [id])
  expiresAt DateTime
  used      Boolean  @default(false)
  createdAt DateTime @default(now())
}

model Feedback {
  id          Int          @id @default(autoincrement())
  userId      Int
  user        User         @relation(fields: [userId], references: [id])
  workspaceId Int?
  workspace   Workspace?   @relation(fields: [workspaceId], references: [id])
  type        FeedbackType
  message     String
  read        Boolean      @default(false)
  createdAt   DateTime     @default(now())
}

enum FeedbackType {
  SUGGESTION
  BUG
}

// ─── WORKSPACE-SCOPED: ROLES, PROYECTOS, SERVICIOS ───────────────────────────

model UserRole {
  id          Int      @id @default(autoincrement())
  workspaceId Int
  workspace   Workspace @relation(fields: [workspaceId], references: [id])
  name        String   // identificador interno, ej: "DESIGNER"
  label       String   // nombre para mostrar, ej: "Diseñador"
  createdAt   DateTime @default(now())

  @@unique([workspaceId, name])
  @@index([workspaceId])
}

model Project {
  id          Int      @id @default(autoincrement())
  workspaceId Int
  workspace   Workspace @relation(fields: [workspaceId], references: [id])
  name        String
  active      Boolean  @default(true)
  situation        String?
  timezone         String  @default("America/Argentina/Buenos_Aires")
  linksEnabled     Boolean @default(true)
  situationEnabled Boolean @default(true)
  emailFrom           String?
  aiWeeklyTokenLimit  Int     @default(500000)
  websiteUrl          String?
  connections         String   @default("{}")  // JSON: { instagram, facebook, ... }
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tasks         Task[]
  services      ProjectService[]
  members       ProjectMember[]
  notifications Notification[]
  links         ProjectLink[]
  geoAudits          GeoAudit[]
  integrations       ProjectIntegration[]
  analyticsSnapshots AnalyticsSnapshot[]
  analyticsInsights  AnalyticsInsight[]
  pageSpeedResults   PageSpeedResult[]
  trackedKeywords    TrackedKeyword[] @relation("ProjectTrackedKeywords")
  keywordRankings           KeywordRanking[] @relation("ProjectKeywordRankings")
  instagramSnapshots        InstagramSnapshot[]
  instagramFollowerLogs     InstagramFollowerLog[]
  tiktokSnapshots           TikTokSnapshot[]
  tiktokFollowerLogs        TikTokFollowerLog[]
  monthlyReports            MonthlyReport[]
  searchConsoleSnapshots    SearchConsoleSnapshot[]
  seoAiInsights             SeoAiInsight[]
  cannibalReports           CannibalReport[]

  @@unique([workspaceId, name])
  @@index([workspaceId])
}

model Service {
  id          Int      @id @default(autoincrement())
  workspaceId Int
  workspace   Workspace @relation(fields: [workspaceId], references: [id])
  name        String
  active      Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  projects ProjectService[]

  @@unique([workspaceId, name])
  @@index([workspaceId])
}

model ProjectService {
  projectId Int
  serviceId Int
  project   Project @relation(fields: [projectId], references: [id])
  service   Service @relation(fields: [serviceId], references: [id])

  @@id([projectId, serviceId])
}

model ProjectMember {
  projectId Int
  userId    Int
  project   Project @relation(fields: [projectId], references: [id])
  user      User    @relation(fields: [userId], references: [id])

  @@id([projectId, userId])
}

model ProjectLink {
  id        Int      @id @default(autoincrement())
  projectId Int
  project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  label     String
  url       String
  createdAt DateTime @default(now())

  @@index([projectId])
}

// ─── WORKDAY & TASKS ─────────────────────────────────────────────────────────

model WorkDay {
  id          Int       @id @default(autoincrement())
  userId      Int
  user        User      @relation(fields: [userId], references: [id])
  workspaceId Int
  workspace   Workspace @relation(fields: [workspaceId], references: [id])
  date        String    // "YYYY-MM-DD"
  startedAt   DateTime  @default(now())
  endedAt     DateTime?
  createdAt   DateTime  @default(now())

  tasks Task[]

  @@unique([userId, workspaceId, date])
  @@index([userId, date])
  @@index([workspaceId, date])
  @@index([date])
}

enum TaskStatus {
  PENDING
  IN_PROGRESS
  PAUSED
  BLOCKED
  COMPLETED
}

model Task {
  id          Int        @id @default(autoincrement())
  workDayId   Int
  workDay     WorkDay    @relation(fields: [workDayId], references: [id])
  userId      Int
  user        User       @relation(fields: [userId], references: [id])
  createdById Int?
  createdBy   User?      @relation("TaskCreatedBy", fields: [createdById], references: [id])
  projectId   Int
  project     Project    @relation(fields: [projectId], references: [id])
  description   String
  status        TaskStatus @default(PENDING)
  blockedReason String?
  startedAt     DateTime?
  pausedAt      DateTime?
  pausedMinutes   Int        @default(0)
  completedAt     DateTime?
  minutesOverride Int?
  starred              Int        @default(0)
  isBacklog            Boolean    @default(false)
  dismissedByCreator   Boolean    @default(false)
  createdAt            DateTime   @default(now())
  updatedAt       DateTime   @updatedAt

  notifications Notification[]
  comments      TaskComment[]
  sessions      TaskSession[]

  @@index([userId, status])
  @@index([projectId])
  @@index([workDayId])
}

model TaskSession {
  id        Int       @id @default(autoincrement())
  taskId    Int
  task      Task      @relation(fields: [taskId], references: [id], onDelete: Cascade)
  startedAt DateTime
  endedAt   DateTime?

  @@index([taskId])
  @@index([startedAt])
}

model TaskComment {
  id        Int          @id @default(autoincrement())
  taskId    Int
  task      Task         @relation(fields: [taskId], references: [id], onDelete: Cascade)
  userId    Int
  user      User         @relation(fields: [userId], references: [id])
  content   String
  parentId  Int?
  parent    TaskComment? @relation("CommentReplies", fields: [parentId], references: [id])
  replies   TaskComment[] @relation("CommentReplies")
  createdAt DateTime     @default(now())

  @@index([taskId])
}

// ─── NOTIFICACIONES ──────────────────────────────────────────────────────────

enum NotificationType {
  COMPLETED
  BLOCKED
  ADDED_TO_PROJECT
  TASK_COMMENT
  TASK_MENTION
  VACATION_REQUEST
  VACATION_REVIEWED
}

model Notification {
  id          Int              @id @default(autoincrement())
  userId      Int
  user        User             @relation("NotificationRecipient", fields: [userId], references: [id])
  actorId     Int
  actor       User             @relation("NotificationActor", fields: [actorId], references: [id])
  workspaceId Int
  workspace   Workspace        @relation(fields: [workspaceId], references: [id])
  taskId      Int?
  task        Task?            @relation(fields: [taskId], references: [id])
  projectId   Int?
  project     Project?         @relation(fields: [projectId], references: [id])
  type        NotificationType @default(COMPLETED)
  message     String
  read        Boolean          @default(false)
  createdAt   DateTime         @default(now())

  @@index([userId])
  @@index([userId, read])
  @@index([workspaceId])
}

// ─── AI: INSIGHTS, MEMORY, TOKENS ────────────────────────────────────────────

model DailyInsight {
  id          Int      @id @default(autoincrement())
  userId      Int
  user        User     @relation(fields: [userId], references: [id])
  workspaceId Int
  workspace   Workspace @relation(fields: [workspaceId], references: [id])
  date        String   // "YYYY-MM-DD" en timezone del workspace
  titulo      String
  mensaje     String
  sugerencia  String?
  alertaRol   String?
  alertaGTD   String?
  tono        String   // warning | alert | positive | neutral
  feedback    String?  // "up" | "down" | null
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([userId, workspaceId, date])
  @@index([userId])
  @@index([workspaceId])
}

model UserInsightMemory {
  id              Int      @id @default(autoincrement())
  userId          Int
  user            User     @relation(fields: [userId], references: [id])
  workspaceId     Int
  workspace       Workspace @relation(fields: [workspaceId], references: [id])
  tendencias      String   @default("")
  fortalezas      String   @default("")
  areasDeAtencion String   @default("")
  estadisticas    Json     @default("{}")
  weekStart       String   @default("") // YYYY-MM-DD
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@unique([userId, workspaceId, weekStart])
  @@index([userId])
  @@index([workspaceId])
}

model AiTokenLog {
  id           Int      @id @default(autoincrement())
  workspaceId  Int?
  workspace    Workspace? @relation(fields: [workspaceId], references: [id])
  service      String   // "insight" | "weeklyReport" | "insightMemory"
  userId       Int?
  inputTokens  Int      @default(0)
  outputTokens Int      @default(0)
  createdAt    DateTime @default(now())

  @@index([createdAt])
  @@index([workspaceId])
}

// ─── ROLES IA ─────────────────────────────────────────────────────────────────

model RoleExpectation {
  id                          Int      @id @default(autoincrement())
  workspaceId                 Int
  workspace                   Workspace @relation(fields: [workspaceId], references: [id])
  roleName                    String
  description                 String   @default("")
  expectedResults             Json     @default("[]")
  operationalResponsibilities Json     @default("[]")
  recurrentTasks              Json     @default("[]")
  dependencies                Json     @default("[]")
  createdAt                   DateTime @default(now())
  updatedAt                   DateTime @updatedAt

  @@unique([workspaceId, roleName])
  @@index([workspaceId])
}

// ─── EMAIL LOG ───────────────────────────────────────────────────────────────

model EmailLog {
  id          Int        @id @default(autoincrement())
  workspaceId Int?
  workspace   Workspace? @relation(fields: [workspaceId], references: [id], onDelete: SetNull)
  to          String     // destinatario(s), puede ser comma-separated
  subject     String
  type        String     // passwordReset | welcome | weeklySummary | testSettings | invitation | deletionWarning
  status      String     @default("sent") // sent | failed
  errorMsg    String?
  createdAt   DateTime   @default(now())

  @@index([workspaceId])
  @@index([createdAt])
  @@index([status])
}

// ─── ELIMINACIÓN DE WORKSPACE ────────────────────────────────────────────────

model WorkspaceDeletionRequest {
  id            Int       @id @default(autoincrement())
  workspaceId   Int       @unique
  workspace     Workspace @relation(fields: [workspaceId], references: [id])
  requestedById Int
  requestedBy   User      @relation("DeletionRequestedBy", fields: [requestedById], references: [id])
  scheduledAt   DateTime  // requestedAt + 48h
  cancelledAt   DateTime?
  cancelledById Int?
  cancelledBy   User?     @relation("DeletionCancelledBy", fields: [cancelledById], references: [id])
  createdAt     DateTime  @default(now())

  @@index([scheduledAt])
}

// ─── INVITACIONES ─────────────────────────────────────────────────────────────

model WorkspaceInvitation {
  id          Int       @id @default(autoincrement())
  workspaceId Int
  workspace   Workspace @relation(fields: [workspaceId], references: [id])
  email       String
  token       String    @unique
  memberRole  String    @default("member")   // "admin" | "member"
  teamRole    String    @default("")
  invitedById Int
  invitedBy   User      @relation("InvitedByUser", fields: [invitedById], references: [id])
  expiresAt   DateTime
  usedAt      DateTime?
  createdAt   DateTime  @default(now())

  @@index([workspaceId])
  @@index([email, workspaceId])
}

// ─── VACACIONES ──────────────────────────────────────────────────────────────

model VacationAdjustment {
  id          Int       @id @default(autoincrement())
  workspaceId Int
  workspace   Workspace @relation(fields: [workspaceId], references: [id])
  userId      Int
  user        User      @relation("VacationAdjustmentUser",  fields: [userId],  references: [id])
  adminId     Int
  admin       User      @relation("VacationAdjustmentAdmin", fields: [adminId], references: [id])
  prevDays    Int
  newDays     Int
  description String
  createdAt   DateTime  @default(now())

  @@index([workspaceId, userId])
}

model VacationRequest {
  id          Int       @id @default(autoincrement())
  workspaceId Int
  workspace   Workspace @relation(fields: [workspaceId], references: [id])
  userId      Int
  user        User      @relation("VacationRequestUser",     fields: [userId],     references: [id])
  startDate   String    // YYYY-MM-DD
  endDate     String    // YYYY-MM-DD
  type        String    // "vacaciones" | "estudio" | "maternidad" | "paternidad" | "enfermedad" | "duelo" | "mudanza" | "otro"
  observation String?
  status      String    @default("pending")  // "pending" | "approved" | "rejected"
  reviewedById Int?
  reviewedBy  User?     @relation("VacationRequestReviewer", fields: [reviewedById], references: [id])
  reviewedAt  DateTime?
  reviewNote  String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([workspaceId, userId])
  @@index([workspaceId, status])
}

// ─── ANUNCIOS ─────────────────────────────────────────────────────────────────

model Announcement {
  id                 Int       @id @default(autoincrement())
  title              String
  body               String
  type               String    @default("info")   // "info" | "warning" | "maintenance" | "feature"
  targetAll          Boolean   @default(true)
  targetWorkspaceIds String    @default("[]")      // JSON: [1, 2, 3] — usado cuando targetAll = false
  active             Boolean   @default(false)
  startsAt           DateTime?
  endsAt             DateTime?
  createdById        Int
  createdBy          User      @relation("AnnouncementCreatedBy", fields: [createdById], references: [id])
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt

  @@index([active])
}

// ─── MARKETING / GEO ─────────────────────────────────────────────────────────

model GeoAudit {
  id             Int      @id @default(autoincrement())
  workspaceId    Int
  projectId      Int
  url            String
  status         String   @default("pending") // pending | running | completed | failed
  score          Int?
  citability     Int?
  brandAuthority Int?
  eeat           Int?
  technical      Int?
  schema         Int?
  platforms      Int?
  findings       String   @default("[]")       // JSON: [{severity, component, title, description}]
  recommendations String  @default("[]")       // JSON: [{priority, action, impact}]
  rawData        String?
  errorMsg       String?
  tokensUsed     Int?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  workspace Workspace @relation(fields: [workspaceId], references: [id])
  project   Project   @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([workspaceId])
  @@index([projectId])
}

// ─── FEATURE FLAGS ───────────────────────────────────────────────────────────

model FeatureFlag {
  id                 Int      @id @default(autoincrement())
  key                String   @unique   // ej: "vacation_requests"
  name               String             // nombre legible, ej: "Solicitud de vacaciones"
  description        String   @default("")
  enabledGlobally    Boolean  @default(false)
  enabledWorkspaceIds String  @default("[]") // JSON: [1, 2] — workspaces con acceso cuando !enabledGlobally
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  @@index([key])
}

// ─── INTEGRACIONES EXTERNAS ──────────────────────────────────────────────────

model ProjectIntegration {
  id          Int      @id @default(autoincrement())
  workspaceId Int
  projectId   Int
  type        String   // "google_analytics" | "google_ads"
  status      String   @default("active") // "active" | "error" | "revoked"

  propertyId   String?  // GA4: "properties/123456789"
  customerId   String?  // Google Ads: "123-456-7890"
  country      String   @default("arg") // ISO 3166-1 alpha-3 lowercase (arg, mex, esp…) — país de referencia para keywords

  // Tokens cifrados (AES-256-GCM, formato "iv:tag:ciphertext" hex)
  accessToken  String?
  refreshToken String?
  expiresAt    DateTime?
  scopes       String   @default("")

  connectedById Int?
  connectedAt   DateTime @default(now())
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  workspace Workspace @relation(fields: [workspaceId], references: [id])
  project   Project   @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@unique([projectId, type])
  @@index([workspaceId])
  @@index([projectId])
}

// ─── AVATARES ─────────────────────────────────────────────────────────────────

model Avatar {
  id        Int      @id @default(autoincrement())
  filename  String   @unique
  label     String
  order     Int      @default(0)
  active    Boolean  @default(true)
  imageData Bytes
  mimeType  String   @default("image/png")
  createdAt DateTime @default(now())

  @@index([order])
  @@index([active])
}

// ─── DOCUMENTOS LEGALES ───────────────────────────────────────────────────────

model LegalDocument {
  id        Int      @id @default(autoincrement())
  key       String   @unique  // e.g. "terms_of_service"
  title     String
  content   String   @default("")
  updatedAt DateTime @updatedAt
  createdAt DateTime @default(now())
}

// ─── ANALYTICS SNAPSHOTS ──────────────────────────────────────────────────────

model AnalyticsSnapshot {
  id          Int      @id @default(autoincrement())
  workspaceId Int
  projectId   Int
  month       String   // "2026-04" (YYYY-MM)

  sessions    Int      @default(0)
  activeUsers Int      @default(0)
  newUsers    Int      @default(0)
  pageviews   Int      @default(0)
  bounceRate  Float    @default(0)
  avgDuration Float    @default(0)   // segundos
  conversions Int      @default(0)
  topChannels String   @default("[]") // JSON: [{channel, sessions, users}]
  aiTraffic   String   @default("{}") // JSON: { chatgpt, claude, gemini, grok, metaAi, perplexity, copilot, other }

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  workspace   Workspace @relation(fields: [workspaceId], references: [id])
  project     Project   @relation(fields: [projectId],   references: [id], onDelete: Cascade)

  @@unique([projectId, month])
  @@index([workspaceId])
  @@index([projectId])
}

model AnalyticsInsight {
  id          Int      @id @default(autoincrement())
  workspaceId Int
  projectId   Int
  month       String   // "2026-04"

  // JSON: { titulo, resumen, tendencias: [{metrica, delta, positivo}], recomendaciones: [string] }
  content     String
  generatedAt DateTime @default(now())

  workspace   Workspace @relation(fields: [workspaceId], references: [id])
  project     Project   @relation(fields: [projectId],   references: [id], onDelete: Cascade)

  @@unique([projectId, month])
  @@index([workspaceId])
  @@index([projectId])
}

// ─── PAGESPEED RESULTS ────────────────────────────────────────────────────────

model PageSpeedResult {
  id          Int      @id @default(autoincrement())
  workspaceId Int
  projectId   Int
  url         String
  strategy    String   @default("mobile")  // "mobile" | "desktop"
  status      String   @default("running") // "running" | "done" | "error"

  performanceScore Int?   // 0-100

  // JSON: { lcp, fcp, tbt, cls, si, ttfb } con { displayValue, numericValue, score, rating }
  metrics      String  @default("{}")

  // JSON: [{ id, title, description, savingsMs, score }]
  opportunities String @default("[]")

  // JSON: [{ id, title, description, score }]
  diagnostics   String @default("[]")

  errorMsg    String?
  createdAt   DateTime @default(now())

  workspace   Workspace @relation(fields: [workspaceId], references: [id])
  project     Project   @relation(fields: [projectId],   references: [id], onDelete: Cascade)

  @@index([workspaceId])
  @@index([projectId])
}

// ─── KEYWORD TRACKING ─────────────────────────────────────────────────────────

model TrackedKeyword {
  id                Int       @id @default(autoincrement())
  projectId         Int
  workspaceId       Int
  query             String
  analysisContent   String?   // JSON output de Claude (cacheado)
  analysisUpdatedAt DateTime?
  createdAt         DateTime  @default(now())

  project   Project   @relation("ProjectTrackedKeywords",   fields: [projectId],   references: [id], onDelete: Cascade)
  workspace Workspace @relation("WorkspaceTrackedKeywords", fields: [workspaceId], references: [id], onDelete: Cascade)
  rankings  KeywordRanking[]

  @@unique([projectId, query])
  @@index([projectId, workspaceId])
}

model KeywordRanking {
  id               Int      @id @default(autoincrement())
  trackedKeywordId Int
  projectId        Int
  workspaceId      Int
  month            String   // "2026-04"
  clicks           Int      @default(0)
  impressions      Int      @default(0)
  ctr              Float    @default(0)
  position         Float    @default(0)
  createdAt        DateTime @default(now())

  trackedKeyword TrackedKeyword @relation(fields: [trackedKeywordId], references: [id], onDelete: Cascade)
  project        Project        @relation("ProjectKeywordRankings",   fields: [projectId],   references: [id], onDelete: Cascade)
  workspace      Workspace      @relation("WorkspaceKeywordRankings", fields: [workspaceId], references: [id], onDelete: Cascade)

  @@unique([trackedKeywordId, month])
  @@index([projectId, workspaceId])
}

