generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── WORKSPACE ───────────────────────────────────────────────────────────────

model Workspace {
  id               Int      @id @default(autoincrement())
  name             String
  slug             String   @unique   // subdominio, ej: "bliss"
  timezone         String   @default("America/Argentina/Buenos_Aires")
  status           String   @default("trialing") // trialing | active | past_due | suspended | cancelled
  trialEndsAt      DateTime?
  stripeCustomerId String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  members          WorkspaceMember[]
  projects         Project[]
  userRoles        UserRole[]
  services         Service[]
  roleExpectations RoleExpectation[]
  aiTokenLogs      AiTokenLog[]
  dailyInsights    DailyInsight[]
  insightMemories  UserInsightMemory[]
  notifications    Notification[]
  workDays         WorkDay[]
  subscription     Subscription?
  loginEvents      UserLogin[]
  feedbacks        Feedback[]
  invitations      WorkspaceInvitation[]

  @@index([slug])
}

model WorkspaceMember {
  workspaceId Int
  userId      Int
  workspace   Workspace @relation(fields: [workspaceId], references: [id])
  user        User      @relation(fields: [userId], references: [id])

  role        String    @default("member")   // "owner" | "admin" | "member"
  teamRole    String    @default("")          // ej: "DESIGNER", "CM" (referencia a UserRole.name)
  active      Boolean   @default(true)
  vacationDays Int      @default(0)

  // Preferencias IA (por workspace)
  weeklyEmailEnabled    Boolean @default(true)
  dailyInsightEnabled   Boolean @default(true)
  insightMemoryEnabled  Boolean @default(true)
  taskQualityEnabled    Boolean @default(true)

  joinedAt    DateTime  @default(now())

  @@id([workspaceId, userId])
  @@index([workspaceId])
  @@index([userId])
}

model Subscription {
  id             Int      @id @default(autoincrement())
  workspaceId    Int      @unique
  workspace      Workspace @relation(fields: [workspaceId], references: [id])
  stripeSubId    String?  @unique
  planName       String   @default("pro")
  status         String   // active | past_due | cancelled | trialing
  seats          Int      @default(0)
  periodStart    DateTime?
  periodEnd      DateTime?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}

// ─── USER (global — datos personales, no workspace-specific) ─────────────────

model User {
  id        Int      @id @default(autoincrement())
  name      String
  email     String   @unique
  password  String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Super admin global (solo equipo Bliss)
  isSuperAdmin Boolean @default(false)

  // Datos personales (opcionales, globales al usuario)
  phone             String?
  birthday          DateTime?
  address           String?
  dni               String?
  cuit              String?
  alias             String?
  bankName          String?
  maritalStatus     String?
  children          Int?
  educationLevel    String?
  educationTitle    String?
  bloodType         String?
  medicalConditions String?
  healthInsurance   String?
  emergencyContact  String?
  avatar            String   @default("bee.png")

  // Relaciones
  workspaceMembers      WorkspaceMember[]
  workDays              WorkDay[]
  tasks                 Task[]
  tasksCreated          Task[]         @relation("TaskCreatedBy")
  taskComments          TaskComment[]
  dailyInsights         DailyInsight[]
  insightMemories       UserInsightMemory[]
  feedbacks             Feedback[]
  projects              ProjectMember[]
  notifications         Notification[] @relation("NotificationRecipient")
  notificationsAsActor  Notification[] @relation("NotificationActor")
  passwordResetTokens   PasswordResetToken[]
  loginEvents           UserLogin[]
  sentInvitations       WorkspaceInvitation[] @relation("InvitedByUser")
}

model UserLogin {
  id          Int       @id @default(autoincrement())
  userId      Int
  user        User      @relation(fields: [userId], references: [id])
  workspaceId Int?
  workspace   Workspace? @relation(fields: [workspaceId], references: [id])
  loginAt     DateTime  @default(now())
  method      String    // "email" | "google"

  @@index([userId])
  @@index([workspaceId])
  @@index([loginAt])
}

model PasswordResetToken {
  id        Int      @id @default(autoincrement())
  token     String   @unique
  userId    Int
  user      User     @relation(fields: [userId], references: [id])
  expiresAt DateTime
  used      Boolean  @default(false)
  createdAt DateTime @default(now())
}

model Feedback {
  id          Int          @id @default(autoincrement())
  userId      Int
  user        User         @relation(fields: [userId], references: [id])
  workspaceId Int?
  workspace   Workspace?   @relation(fields: [workspaceId], references: [id])
  type        FeedbackType
  message     String
  read        Boolean      @default(false)
  createdAt   DateTime     @default(now())
}

enum FeedbackType {
  SUGGESTION
  BUG
}

// ─── WORKSPACE-SCOPED: ROLES, PROYECTOS, SERVICIOS ───────────────────────────

model UserRole {
  id          Int      @id @default(autoincrement())
  workspaceId Int
  workspace   Workspace @relation(fields: [workspaceId], references: [id])
  name        String   // identificador interno, ej: "DESIGNER"
  label       String   // nombre para mostrar, ej: "Diseñador"
  createdAt   DateTime @default(now())

  @@unique([workspaceId, name])
  @@index([workspaceId])
}

model Project {
  id          Int      @id @default(autoincrement())
  workspaceId Int
  workspace   Workspace @relation(fields: [workspaceId], references: [id])
  name        String
  active      Boolean  @default(true)
  situation        String?
  timezone         String  @default("America/Argentina/Buenos_Aires")
  linksEnabled     Boolean @default(true)
  situationEnabled Boolean @default(true)
  emailFrom           String?
  aiWeeklyTokenLimit  Int     @default(500000)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tasks         Task[]
  services      ProjectService[]
  members       ProjectMember[]
  notifications Notification[]
  links         ProjectLink[]

  @@unique([workspaceId, name])
  @@index([workspaceId])
}

model Service {
  id          Int      @id @default(autoincrement())
  workspaceId Int
  workspace   Workspace @relation(fields: [workspaceId], references: [id])
  name        String
  active      Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  projects ProjectService[]

  @@unique([workspaceId, name])
  @@index([workspaceId])
}

model ProjectService {
  projectId Int
  serviceId Int
  project   Project @relation(fields: [projectId], references: [id])
  service   Service @relation(fields: [serviceId], references: [id])

  @@id([projectId, serviceId])
}

model ProjectMember {
  projectId Int
  userId    Int
  project   Project @relation(fields: [projectId], references: [id])
  user      User    @relation(fields: [userId], references: [id])

  @@id([projectId, userId])
}

model ProjectLink {
  id        Int      @id @default(autoincrement())
  projectId Int
  project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  label     String
  url       String
  createdAt DateTime @default(now())

  @@index([projectId])
}

// ─── WORKDAY & TASKS ─────────────────────────────────────────────────────────

model WorkDay {
  id          Int       @id @default(autoincrement())
  userId      Int
  user        User      @relation(fields: [userId], references: [id])
  workspaceId Int
  workspace   Workspace @relation(fields: [workspaceId], references: [id])
  date        String    // "YYYY-MM-DD"
  startedAt   DateTime  @default(now())
  endedAt     DateTime?
  createdAt   DateTime  @default(now())

  tasks Task[]

  @@unique([userId, workspaceId, date])
  @@index([userId, date])
  @@index([workspaceId, date])
  @@index([date])
}

enum TaskStatus {
  PENDING
  IN_PROGRESS
  PAUSED
  BLOCKED
  COMPLETED
}

model Task {
  id          Int        @id @default(autoincrement())
  workDayId   Int
  workDay     WorkDay    @relation(fields: [workDayId], references: [id])
  userId      Int
  user        User       @relation(fields: [userId], references: [id])
  createdById Int?
  createdBy   User?      @relation("TaskCreatedBy", fields: [createdById], references: [id])
  projectId   Int
  project     Project    @relation(fields: [projectId], references: [id])
  description   String
  status        TaskStatus @default(PENDING)
  blockedReason String?
  startedAt     DateTime?
  pausedAt      DateTime?
  pausedMinutes   Int        @default(0)
  completedAt     DateTime?
  minutesOverride Int?
  starred         Int        @default(0)
  isBacklog       Boolean    @default(false)
  createdAt       DateTime   @default(now())
  updatedAt       DateTime   @updatedAt

  notifications Notification[]
  comments      TaskComment[]
  sessions      TaskSession[]

  @@index([userId, status])
  @@index([projectId])
  @@index([workDayId])
}

model TaskSession {
  id        Int       @id @default(autoincrement())
  taskId    Int
  task      Task      @relation(fields: [taskId], references: [id], onDelete: Cascade)
  startedAt DateTime
  endedAt   DateTime?

  @@index([taskId])
  @@index([startedAt])
}

model TaskComment {
  id        Int          @id @default(autoincrement())
  taskId    Int
  task      Task         @relation(fields: [taskId], references: [id], onDelete: Cascade)
  userId    Int
  user      User         @relation(fields: [userId], references: [id])
  content   String
  parentId  Int?
  parent    TaskComment? @relation("CommentReplies", fields: [parentId], references: [id])
  replies   TaskComment[] @relation("CommentReplies")
  createdAt DateTime     @default(now())

  @@index([taskId])
}

// ─── NOTIFICACIONES ──────────────────────────────────────────────────────────

enum NotificationType {
  COMPLETED
  BLOCKED
  ADDED_TO_PROJECT
  TASK_COMMENT
  TASK_MENTION
}

model Notification {
  id          Int              @id @default(autoincrement())
  userId      Int
  user        User             @relation("NotificationRecipient", fields: [userId], references: [id])
  actorId     Int
  actor       User             @relation("NotificationActor", fields: [actorId], references: [id])
  workspaceId Int
  workspace   Workspace        @relation(fields: [workspaceId], references: [id])
  taskId      Int?
  task        Task?            @relation(fields: [taskId], references: [id])
  projectId   Int
  project     Project          @relation(fields: [projectId], references: [id])
  type        NotificationType @default(COMPLETED)
  message     String
  read        Boolean          @default(false)
  createdAt   DateTime         @default(now())

  @@index([userId])
  @@index([userId, read])
  @@index([workspaceId])
}

// ─── AI: INSIGHTS, MEMORY, TOKENS ────────────────────────────────────────────

model DailyInsight {
  id          Int      @id @default(autoincrement())
  userId      Int
  user        User     @relation(fields: [userId], references: [id])
  workspaceId Int
  workspace   Workspace @relation(fields: [workspaceId], references: [id])
  date        String   // "YYYY-MM-DD" en timezone del workspace
  titulo      String
  mensaje     String
  sugerencia  String?
  alertaRol   String?
  alertaGTD   String?
  tono        String   // warning | alert | positive | neutral
  feedback    String?  // "up" | "down" | null
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([userId, workspaceId, date])
  @@index([userId])
  @@index([workspaceId])
}

model UserInsightMemory {
  id              Int      @id @default(autoincrement())
  userId          Int
  user            User     @relation(fields: [userId], references: [id])
  workspaceId     Int
  workspace       Workspace @relation(fields: [workspaceId], references: [id])
  tendencias      String   @default("")
  fortalezas      String   @default("")
  areasDeAtencion String   @default("")
  estadisticas    Json     @default("{}")
  weekStart       String   @default("") // YYYY-MM-DD
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@unique([userId, workspaceId, weekStart])
  @@index([userId])
  @@index([workspaceId])
}

model AiTokenLog {
  id           Int      @id @default(autoincrement())
  workspaceId  Int?
  workspace    Workspace? @relation(fields: [workspaceId], references: [id])
  service      String   // "insight" | "weeklyReport" | "insightMemory"
  userId       Int?
  inputTokens  Int      @default(0)
  outputTokens Int      @default(0)
  createdAt    DateTime @default(now())

  @@index([createdAt])
  @@index([workspaceId])
}

// ─── ROLES IA ─────────────────────────────────────────────────────────────────

model RoleExpectation {
  id                          Int      @id @default(autoincrement())
  workspaceId                 Int
  workspace                   Workspace @relation(fields: [workspaceId], references: [id])
  roleName                    String
  description                 String   @default("")
  expectedResults             Json     @default("[]")
  operationalResponsibilities Json     @default("[]")
  recurrentTasks              Json     @default("[]")
  dependencies                Json     @default("[]")
  createdAt                   DateTime @default(now())
  updatedAt                   DateTime @updatedAt

  @@unique([workspaceId, roleName])
  @@index([workspaceId])
}

// ─── INVITACIONES ─────────────────────────────────────────────────────────────

model WorkspaceInvitation {
  id          Int       @id @default(autoincrement())
  workspaceId Int
  workspace   Workspace @relation(fields: [workspaceId], references: [id])
  email       String
  token       String    @unique
  memberRole  String    @default("member")   // "admin" | "member"
  teamRole    String    @default("")
  invitedById Int
  invitedBy   User      @relation("InvitedByUser", fields: [invitedById], references: [id])
  expiresAt   DateTime
  usedAt      DateTime?
  createdAt   DateTime  @default(now())

  @@index([workspaceId])
  @@index([email, workspaceId])
}
