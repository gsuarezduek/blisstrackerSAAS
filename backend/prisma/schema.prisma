// ─── SEO SNAPSHOTS ────────────────────────────────────────────────────────────

model SearchConsoleSnapshot {
  id          Int      @id @default(autoincrement())
  projectId   Int
  workspaceId Int
  month       String   // "YYYY-MM"

  clicks      Int      @default(0)
  impressions Int      @default(0)
  ctr         Float    @default(0)
  avgPosition Float    @default(0)
  devices     String   @default("{}") // JSON: {DESKTOP:{clicks,impressions}, MOBILE:{...}, TABLET:{...}}
  countries   String   @default("[]") // JSON: [{country, clicks, impressions}]
  topQueries  String   @default("[]") // JSON: [{query, clicks, impressions, ctr, position}]
  topPages    String   @default("[]") // JSON: [{page, clicks, impressions, ctr, position}]

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  project     Project   @relation(fields: [projectId],   references: [id], onDelete: Cascade)
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@unique([projectId, month])
  @@index([workspaceId])
  @@index([projectId])
}

model SeoAiInsight {
  id          Int      @id @default(autoincrement())
  projectId   Int      @unique
  workspaceId Int
  // JSON: { titulo, resumen, oportunidades:[{pagina,accion,impacto,razon}], quickWins:[{titulo,descripcion,tarea}] }
  content     String
  generatedAt DateTime @default(now())

  project     Project   @relation(fields: [projectId],   references: [id], onDelete: Cascade)
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@index([workspaceId])
}

// ─── CANIBALIZACIÓN SEO ──────────────────────────────────────────────────────

model CannibalReport {
  id              Int      @id @default(autoincrement())
  projectId       Int
  workspaceId     Int
  status          String   @default("pending") // pending | running | completed | failed
  dateRange       String   @default("90d")     // "30d" | "90d" | "180d"

  totalConflicts  Int?
  criticalCount   Int?
  warningCount    Int?
  lowCount        Int?
  trafficAtRisk   Int?     // impresiones en riesgo (suma de conflictos críticos + warning)

  // JSON: [{ query, urls:[{url,clicks,impressions,ctr,position}], severity, severityScore,
  //          totalImpressions, totalClicks, positionSpread, recommendation }]
  conflicts       String   @default("[]")

  resumenGeneral  String?  // análisis IA resumido
  errorMsg        String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  project   Project   @relation(fields: [projectId],   references: [id], onDelete: Cascade)
  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@index([projectId, workspaceId])
  @@index([workspaceId])
}
