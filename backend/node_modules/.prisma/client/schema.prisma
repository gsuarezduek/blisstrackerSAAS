generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model UserRole {
  id        Int      @id @default(autoincrement())
  name      String   @unique // identificador interno, ej: "DESIGNER"
  label     String // nombre para mostrar, ej: "Diseñador"
  createdAt DateTime @default(now())
}

enum TaskStatus {
  PENDING
  IN_PROGRESS
  PAUSED
  COMPLETED
}

model User {
  id        Int      @id @default(autoincrement())
  name      String
  email     String   @unique
  password  String
  role      String
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  workDays             WorkDay[]
  tasks                Task[]
  feedbacks            Feedback[]
  projects             ProjectMember[]
  notifications        Notification[]  @relation("NotificationRecipient")
  notificationsAsActor Notification[]  @relation("NotificationActor")
}

model Feedback {
  id        Int          @id @default(autoincrement())
  userId    Int
  user      User         @relation(fields: [userId], references: [id])
  type      FeedbackType
  message   String
  read      Boolean      @default(false)
  createdAt DateTime     @default(now())
}

enum FeedbackType {
  SUGGESTION
  BUG
}

model Project {
  id        Int      @id @default(autoincrement())
  name      String   @unique
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tasks         Task[]
  services      ProjectService[]
  members       ProjectMember[]
  notifications Notification[]
}

model Service {
  id        Int      @id @default(autoincrement())
  name      String   @unique
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  projects ProjectService[]
}

model ProjectService {
  projectId Int
  serviceId Int
  project   Project @relation(fields: [projectId], references: [id])
  service   Service @relation(fields: [serviceId], references: [id])

  @@id([projectId, serviceId])
}

model ProjectMember {
  projectId Int
  userId    Int
  project   Project @relation(fields: [projectId], references: [id])
  user      User    @relation(fields: [userId], references: [id])

  @@id([projectId, userId])
}

model WorkDay {
  id        Int       @id @default(autoincrement())
  userId    Int
  user      User      @relation(fields: [userId], references: [id])
  date      String // "YYYY-MM-DD"
  startedAt DateTime  @default(now())
  endedAt   DateTime?
  createdAt DateTime  @default(now())

  tasks Task[]

  @@unique([userId, date])
}

model Notification {
  id        Int      @id @default(autoincrement())
  userId    Int // destinatario
  user      User     @relation("NotificationRecipient", fields: [userId], references: [id])
  actorId   Int // quien completó la tarea
  actor     User     @relation("NotificationActor", fields: [actorId], references: [id])
  taskId    Int
  task      Task     @relation(fields: [taskId], references: [id])
  projectId Int
  project   Project  @relation(fields: [projectId], references: [id])
  message   String // ej: completó "Diseño logo" en Bliss
  read      Boolean  @default(false)
  createdAt DateTime @default(now())
}

model Task {
  id            Int        @id @default(autoincrement())
  workDayId     Int
  workDay       WorkDay    @relation(fields: [workDayId], references: [id])
  userId        Int
  user          User       @relation(fields: [userId], references: [id])
  projectId     Int
  project       Project    @relation(fields: [projectId], references: [id])
  description   String
  status        TaskStatus @default(PENDING)
  startedAt     DateTime?
  pausedAt      DateTime?
  pausedMinutes Int        @default(0)
  completedAt   DateTime?
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt

  notifications Notification[]
}
